# Copy to .env.local and fill from Supabase → Settings → API.
# When BOTH are set, the app runs in shared cloud mode (link-share collab).
# When absent, it runs fully local (IndexedDB) — no backend needed.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Require login (magic-code) + member management + comment notifications.
# Leave unset for anonymous link-share. Only flip to true AFTER running
# supabase/schema-auth.sql and the Edge Function setup — see SETUP-auth.md.
# VITE_REQUIRE_AUTH=true
